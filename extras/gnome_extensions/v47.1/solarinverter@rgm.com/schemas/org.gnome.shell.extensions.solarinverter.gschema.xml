<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.solarinverter"
    path="/org/gnome/shell/extensions/solarinverter/">
    <key type="s" name="host">
      <default>"localhost:9999"</default>
      <summary>host</summary>
      <description>Server address and port</description>
    </key>
    <key type="d" name="battery-wh">
      <default>6600</default>
      <summary>W/h</summary>
      <description>Battery capacity in watts/hours</description>
    </key>
    <key type="i" name="battery-dod">
      <default>50</default>
      <summary>Percentage</summary>
      <description>Battery recommended depth of discharge</description>
    </key>
    <key type="i" name="dummy">
      <default>0</default>
      <summary>Dummy</summary>
      <description>Dummy value</description>
    </key>
  </schema>
</schemalist>
